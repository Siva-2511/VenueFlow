# .env.example
# 📋 Copy this file to .env and fill in your actual credentials
# Strictly NO secrets should be committed to version control.

# Google Gemini API Key from Google AI Studio
GEMINI_API_KEY=your_gemini_api_key_here

# Flask Session Security Key (Any long random string)
SESSION_KEY=your_secret_key_here

# Cloudflare D1 Credentials (Only required if running with D1 backend)
D1_API_TOKEN=your_cloudflare_token_here
D1_ACCOUNT_ID=your_account_id_here

# Google OAuth Credentials (Optional: For Google Login)
GOOGLE_CLIENT_ID=your_client_id
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8080/auth/google/callback

# Environment Flags
RENDER=false
PORT=8080
